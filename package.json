{
  "name": "fusion-harness",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.16.0",
  "workspaces": [
    "apps/web",
    "workers/api",
    "workers/mcp",
    "packages/core",
    "packages/db",
    "packages/shared",
    "packages/ui"
  ],
  "scripts": {
    "dev": "npm run dev -w @fusion-harness/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present && npm run runner:test",
    "preview": "npm run typecheck && npm run lint && npm run build && npm run test",
    "deploy": "npm run deploy:cloudflare",
    "web:dev": "npm run dev -w @fusion-harness/web",
    "web:build": "npm run build -w @fusion-harness/web",
    "web:lint": "npm run lint -w @fusion-harness/web",
    "web:preview": "npm run preview -w @fusion-harness/web",
    "web:deploy": "npm run deploy -w @fusion-harness/web",
    "api:dev": "npm run dev -w @fusion-harness/api",
    "api:build": "npm run build -w @fusion-harness/api",
    "api:deploy": "npm run deploy -w @fusion-harness/api",
    "api:migrate:local": "npm run migrate:local -w @fusion-harness/api",
    "api:migrate:remote": "npm run migrate:remote -w @fusion-harness/api",
    "mcp:dev": "npm run dev -w @fusion-harness/mcp",
    "mcp:build": "npm run build -w @fusion-harness/mcp",
    "mcp:deploy": "npm run deploy -w @fusion-harness/mcp",
    "deploy:cloudflare": "npm run typecheck && npm run api:migrate:remote && npm run api:deploy && npm run mcp:deploy && npm run web:deploy",
    "runner:build": "cd apps/runner-go && go build -o fusion-runner ./cmd/fusion-runner",
    "runner:install:macos": "scripts/install-runner-macos.sh",
    "runner:install:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-runner-windows.ps1",
    "runner:uninstall:macos": "scripts/uninstall-runner-macos.sh",
    "runner:uninstall:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/uninstall-runner-windows.ps1",
    "runner:logs:macos": "tail -n 80 -f ~/.fusion-harness/logs/runner.out.log ~/.fusion-harness/logs/runner.err.log",
    "runner:logs:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/show-runner-logs-windows.ps1",
    "runner:test": "cd apps/runner-go && go test ./..."
  },
  "devDependencies": {
    "typescript": "^5.7.4"
  }
}
